# Server Configuration
PROJECT_NAME="Inventory & Order Management System"
ENVIRONMENT=development
SECRET_KEY=generate_a_secure_random_key_in_production
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration (Neon serverless PostgreSQL)
# Copy the connection string directly from your Neon Console (Connection Details card).
# Format: postgres://[user]:[password]@[neon-project-id].[region].aws.neon.tech/[dbname]?sslmode=require
# Note: Pydantic configuration validates and converts 'postgres://' into SQLAlchemy 'postgresql://' automatically.
DATABASE_URL=postgres://alex:examplepassword123@ep-cool-snowflake-12345.us-east-2.aws.neon.tech/neondb?sslmode=require
